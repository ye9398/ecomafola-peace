# Shopify Storefront API Configuration
# Get your token from: https://help.shopify.com/en/manual/customers/storefront-api-access

VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-token

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# (Optional) Google Search Console Verification
# Get from Search Console > Settings > Ownership verification
VITE_GOOGLE_SITE_VERIFICATION=your-verification-code
